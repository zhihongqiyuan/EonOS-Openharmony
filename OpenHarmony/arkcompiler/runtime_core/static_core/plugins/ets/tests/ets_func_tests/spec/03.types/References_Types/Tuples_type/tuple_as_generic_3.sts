/*---
desc: 03.8.10 Tuple Types
name: tuple_as_generic_3.sts
tags: []
---*/

type StringNumberPair = [String, Number];

class TupleFunction<T> {
    field: T;
    public get(): T {
        return this.field;
    }
}

function main(): void {
    let ct = new TupleFunction<StringNumberPair>();
    ct.field = ["12", 12.0];

    let getme = ct.get();

    assert getme[0] == "12";
    assert getme[1] == 12
}
